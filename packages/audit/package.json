{
  "name": "@atelier-oss/audit",
  "version": "0.1.0",
  "description": "Project audit \u2014 token usage, contrast, motion, accessibility, design coverage, responsive layout.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean --target node20",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/node": "^20.17.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/atelier-oss/atelier.git",
    "directory": "packages/audit"
  },
  "homepage": "https://github.com/atelier-oss/atelier#readme",
  "bugs": {
    "url": "https://github.com/atelier-oss/atelier/issues"
  }
}
