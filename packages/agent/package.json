{
  "name": "@atelier-oss/agent",
  "version": "0.0.1",
  "description": "Atelier Design Agent — text-brief-to-token-conformant React/Tailwind code via Sonnet + atelier_classify. Phase 0 skeleton.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "eval"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean --target node20",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "eval": "tsx eval/runner.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@atelier-oss/classify": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.17.0",
    "tsup": "^8.3.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/atelier-oss/atelier.git",
    "directory": "packages/agent"
  },
  "homepage": "https://github.com/atelier-oss/atelier#readme",
  "bugs": {
    "url": "https://github.com/atelier-oss/atelier/issues"
  }
}
