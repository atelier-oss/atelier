{
  "name": "@atelier/cli",
  "version": "0.0.0",
  "description": "Atelier CLI — DESIGN.md-aware design-token toolkit. v0 generates. Cursor edits. Atelier enforces.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "atelier": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/cli.ts --format esm --dts --clean --target node20",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@atelier/atlas": "workspace:*",
    "@atelier/audit": "workspace:*",
    "@atelier/classify": "workspace:*",
    "@atelier/lint": "workspace:*",
    "citty": "^0.1.6"
  },
  "devDependencies": {
    "@types/node": "^20.17.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  }
}
