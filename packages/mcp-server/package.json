{
  "name": "@atelier/mcp-server",
  "version": "0.1.0",
  "description": "MCP server exposing Atelier tools (lint, classify, audit, atlas_fingerprint) over stdio.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "atelier-mcp": "./dist/server.js"
  },
  "scripts": {
    "build": "tsup src/index.ts src/server.ts --format esm --dts --clean --target node20",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@atelier/atlas": "workspace:*",
    "@atelier/audit": "workspace:*",
    "@atelier/classify": "workspace:*",
    "@atelier/lint": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^20.17.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  }
}
