{
  "name": "@atelier-oss/lint",
  "version": "0.1.0",
  "description": "DESIGN.md linter wrapping @google/design.md with the Atelier precedence rule and 8 sub-token vocabulary.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "NOTICE"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean --target node20",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@google/design.md": "0.1.1"
  },
  "devDependencies": {
    "@types/node": "^20.17.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  }
}
