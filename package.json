{
  "name": "atelier",
  "private": true,
  "version": "0.0.0",
  "description": "Design-token toolkit for projects using DESIGN.md (Google Labs spec). v0 generates. Cursor edits. Atelier enforces.",
  "license": "MIT",
  "author": "Alex Hale",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "build": "pnpm -r --filter './packages/*' build",
    "test": "pnpm -r --filter './packages/*' test",
    "typecheck": "pnpm -r --filter './packages/*' typecheck",
    "lint": "pnpm -r --filter './packages/*' lint",
    "clean": "pnpm -r exec rm -rf dist .turbo *.tsbuildinfo",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:publish": "pnpm -r build && changeset publish",
    "parity": "python3 -m benchmarks.parity_check"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.9",
    "tsup": "^8.3.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  }
}
